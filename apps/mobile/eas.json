{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": false
      },
      "bun": "1.3.11",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "bun": "1.3.11",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "bun": "1.3.11",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "sethwebster@gmail.com",
        "ascAppId": "6761669157",
        "appleTeamId": "P8ZBH5878Q"
      }
    }
  }
}
