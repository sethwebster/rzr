{
  "name": "rzr-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "cd packages/rzr && bun run start",
    "test": "cd packages/rzr && bun run test",
    "readme:sync": "node ./scripts/sync-package-readme.mjs",
    "version:patch": "npm version patch --workspace @sethwebster/rzr",
    "mobile:start": "cd apps/mobile && bun run start",
    "mobile:ios": "cd apps/mobile && bun run ios",
    "mobile:ios:device": "cd apps/mobile && bun run ios:device",
    "mobile:android": "cd apps/mobile && bun run android",
    "mobile:web": "cd apps/mobile && bun run web",
    "mobile:lint": "cd apps/mobile && bun run lint",
    "mobile:typecheck": "cd apps/mobile && bun run typecheck"
  },
  "overrides": {
    "lightningcss": "1.32.0"
  }
}
