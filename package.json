{
  "name": "rzr-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "cd packages/rzr && bun run start",
    "test": "cd packages/rzr && bun run test",
    "readme:sync": "node ./scripts/sync-package-readme.mjs",
    "web:sync-version": "node ./scripts/sync-web-version.mjs",
    "web:deploy": "cd apps/web && CLOUDFLARE_ACCOUNT_ID=76a59d239619ed344d267008c790ba18 wrangler pages deploy . --project-name=rzr-live --commit-dirty=true",
    "worker:deploy": "cd packages/rzr-cloudflare && npm run deploy",
    "version:patch": "node -e \"const f='packages/rzr/package.json',p=JSON.parse(require('fs').readFileSync(f,'utf8')),v=p.version.split('.'),r=[v[0],v[1],+v[2]+1].join('.');p.version=r;require('fs').writeFileSync(f,JSON.stringify(p,null,2)+'\\n');console.log('v'+r)\"",
    "publish": "npm run version:patch && npm run readme:sync && npm run web:sync-version && cd packages/rzr && npm publish && cd ../.. && npm run worker:deploy && npm run web:deploy",
    "publish:help": "echo 'Usage: NPM_TOKEN=npm_xxx npm run publish'",
    "mobile:start": "cd apps/mobile && bun run start",
    "mobile:ios": "cd apps/mobile && bun run ios",
    "mobile:ios:device": "cd apps/mobile && bun run ios:device",
    "mobile:android": "cd apps/mobile && bun run android",
    "mobile:web": "cd apps/mobile && bun run web",
    "mobile:lint": "cd apps/mobile && bun run lint",
    "mobile:typecheck": "cd apps/mobile && bun run typecheck",
    "mobile:ota:preview": "cd apps/mobile && bun run ota:preview",
    "mobile:ota:production": "cd apps/mobile && bun run ota:production"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "resolutions": {
    "lightningcss": "1.30.1"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ],
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
