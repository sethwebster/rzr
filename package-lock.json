{
  "name": "rzr-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "rzr-monorepo",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@sethwebster/rzr": {
      "resolved": "packages/rzr",
      "link": true
    },
    "packages/rzr": {
      "name": "@sethwebster/rzr",
      "version": "0.1.4",
      "license": "MIT",
      "bin": {
        "rzr": "src/cli.mjs"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
