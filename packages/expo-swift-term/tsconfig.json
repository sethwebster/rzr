{
  "compilerOptions": {
    "strict": true,
    "noEmit": false,
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "./build",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "plugin/src/**/*.ts"]
}
