+    /// Recalculates the count of lines with images (used after reflow operations)
+    func recalculateLinesWithImagesCount() {
+        var count = 0
+        for i in 0..<lines.count {
+            if lines[i].images != nil {
+                count += 1
+            }
+        }
+        _linesWithImagesCount = count
+    }
