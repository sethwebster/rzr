+    /// Scrolls the content of the terminal one page up
+    public func pageUp()
+    {
+        if terminal.isDisplayBufferAlternate {
+            send (EscapeSequences.cmdPageUp)
+        } else {
+            scrollUp (lines: terminal.rows)
+        }
+    }
