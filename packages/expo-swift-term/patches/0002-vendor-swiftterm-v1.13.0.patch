+    func setCursor (col: Int, row: Int)
+    {
+        let buffer = self.buffer
+        updateRange(borrowing: buffer, buffer.y)
+        if originMode {
+            buffer.x = col + (usingMargins () ? buffer.marginLeft : 0)
+            buffer.y = buffer.scrollTop + row
+        } else {
+            buffer.x = col
+            buffer.y = row
+        }
+        restrictCursor ()
+    }
