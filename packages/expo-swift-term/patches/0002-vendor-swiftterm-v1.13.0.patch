+    func cmdCursorPosition (_ pars: [Int], _ collect: cstring)
+    {
+        setCursor (col: pars.count >= 2 ? (max (1, pars [1])-1) : 0, row: pars.count >= 1 ? (max (1, pars [0]) - 1) : 0)
+    }
