+
+private struct TerminalShellView: View {
+    let connectionInfo: SSHConnectionInfo
+    let onDisconnect: () -> Void
+
+    var body: some View {
+        ZStack(alignment: .topTrailing) {
+            TerminalHostRepresentable(connectionInfo: connectionInfo)
+
