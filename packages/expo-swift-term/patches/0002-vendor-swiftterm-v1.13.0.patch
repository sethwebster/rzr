+    @Test func testGhosttyStyleImplicitNoMatchCases() {
+        let noMatchCases = [
+            "example.com",
+            "www.example.com",
+            "input/output",
+            "foo/bar",
+            "$10/bar",
+            "$10/$20",
+            "$10/bar.txt",
+            "foo/bar,baz.txt",
+            "foo$BAR/baz.txt",
+            "foo~/bar.txt",
+            "// foo bar",
+            "//foo"
