+            return
+        }
+        var s = String (bytes:data, encoding: .utf8)
+        if s == nil {
+            s = String (bytes:data, encoding: .ascii)
+        }
+        if let txt = s {
+            hostCurrentDocument = txt
+            tdel?.hostCurrentDocumentUpdated (source: self)
+        }
+    }
