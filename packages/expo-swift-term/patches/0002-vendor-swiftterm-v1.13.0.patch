+    public static let cmdPageDown: [UInt8] = [ 0x1b, 0x5b, 0x36, 0x7e ]
+    /// Sends the insert key
+    public static let cmdInsert: [UInt8] = [ 0x1b, 0x5b, 0x32, 0x7e ]
+    
+    /// Emacs back-word (meta-b)
+    public static let emacsBack: [UInt8] = [ 0x1b, 0x62]
