+    func cmdCursorForwardTab (_ pars: [Int], _ collect: cstring)
+    {
+        let param = min (cols-1, max (pars.count > 0 ? pars [0] : 1, 1))
+        for _ in 0..<param {
+            buffer.x = buffer.nextTabStop (marginMode: marginMode)
+        }
+    }
