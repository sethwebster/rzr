+    func nsUnderlineStyle(_ style: UnderlineStyle) -> NSUnderlineStyle {
+        switch style {
+        case .none:
+            return []
+        case .single:
+            return .single
+        case .double:
+            return .double
+        case .curly:
+            return .single
+        case .dotted:
+            return [.single, .patternDot]
+        case .dashed:
+            return [.single, .patternDash]
+        }
+    }
