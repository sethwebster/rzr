+            throw NSError(domain: NSOSStatusErrorDomain, code: controlErr, userInfo: nil)
+        }
+        guard let vc = wc.contentViewController as? ViewController else {
+            throw NSError(domain: NSOSStatusErrorDomain, code: controlErr, userInfo: nil)
+        }
+        return vc.terminal.getTerminal().getBufferAsData ()
