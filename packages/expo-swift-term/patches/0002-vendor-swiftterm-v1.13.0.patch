+    /**
+     * Clears the state of the pending display redraw region as well as the dirtyLines set.
+     */
+    public func clearUpdateRange ()
+    {
+        refreshStart = Int.max
+        refreshEnd = -1
+        
+        scrollInvariantRefreshStart = Int.max
+        scrollInvariantRefreshEnd = -1
+    }
