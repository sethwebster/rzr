+        let char0_0 = t.getCharacter (col: 0, row: 0)
+        let char1_0 = t.getCharacter (col: 1, row: 0)
+        let char2_0 = t.getCharacter (col: 2, row: 0)
+        #expect(char0_0 == "\u{1100}")
