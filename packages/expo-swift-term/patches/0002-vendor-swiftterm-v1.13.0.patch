+    private var canConnect: Bool {
+        !username.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && !password.isEmpty
+    }
+
+    var body: some View {
+        ZStack {
+            background
+
+            if let info = connectionInfo {
