+    private static let quadrantUL = BlockElementRect(x0: 0, x1: 4, y0: 0, y1: 4, alpha: .full)
+    private static let quadrantUR = BlockElementRect(x0: 4, x1: 8, y0: 0, y1: 4, alpha: .full)
