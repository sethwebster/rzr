+        if TerminalView.textInputDebugEnabled {
+            print("UITextInput[\(TerminalView.textInputLogCounter + 1)]: send txt=\(txt.debugDescription)")
+            TerminalView.textInputLogCounter += 1
+        }
+        #endif
+        let array = [UInt8] (txt.utf8)
+        send (data: array[...])
+    }
