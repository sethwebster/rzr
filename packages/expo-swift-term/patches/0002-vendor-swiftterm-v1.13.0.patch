+
+import Foundation
+
+enum KittyKey {
+    case unicode(UInt32)
+    case functional(KittyFunctionalKey)
+    case none
+}
+
+enum KittyFunctionalKey {
+    case escape
+    case enter
+    case tab
+    case backspace
+    case insert
+    case delete
+    case up
+    case down
+    case left
+    case right
