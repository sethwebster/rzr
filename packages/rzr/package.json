{
  "name": "@sethwebster/rzr",
  "version": "0.1.7",
  "description": "A razor-thin remote around any terminal process",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "rzr": "src/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethwebster/rzr.git",
    "directory": "packages/rzr"
  },
  "bugs": {
    "url": "https://github.com/sethwebster/rzr/issues"
  },
  "homepage": "https://github.com/sethwebster/rzr#readme",
  "keywords": [
    "tmux",
    "terminal",
    "remote",
    "cli",
    "tty"
  ],
  "scripts": {
    "start": "node ./src/cli.mjs",
    "test": "node --test",
    "tmux:control-spike": "node ./scripts/tmux-control-spike.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "qrcode-terminal": "^0.12.0"
  }
}
